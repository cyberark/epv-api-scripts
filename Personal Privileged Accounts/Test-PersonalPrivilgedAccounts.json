{
    "SafeConfigSet": {
        "default": {
            "CPMName": "PasswordManager",
            "NumberOfDaysRetention": 7,
            "SafeNamePattern": "*_ADM",
            "DefaultSafeMembers": []
        },
        "alt": {
            "NumberOfDaysRetention": 14,
            "SafeEndUserRoleConfigSet": "CustomSafeUser"
        }
    },
    "UserConfigSet": {
        "default": {
            "accountPlatform": "<AccountPlatform>",
            "accountUserPattern": "*_adm",
            "accountAddress": "testenv.corp.com",
            "enableAutoMgmt": "yes"
        }
    },
    "RoleConfigSet": {
        "CustomSafeUser": {
            "useAccounts": true,
            "listAccounts": true
        }
    }
}
